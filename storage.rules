rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Imagens de exercícios - leitura pública, escrita autenticada
    match /exercises/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Outros arquivos - requer autenticação
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
